#######################################
# SOLARYA TRAVEL - CONFIGURAZIONE
# Copia questo file in .env e configura
#######################################

APP_NAME="Solarya Travel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Rome
APP_URL=https://solaryatravel:8890

APP_LOCALE=it
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=it_IT

#######################################
# DATABASE - MAMP MySQL
#######################################
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=8889
DB_DATABASE=solaryatravel
DB_USERNAME=genericUsr
DB_PASSWORD=Password08$
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

#######################################
# CACHE & SESSION
#######################################
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

QUEUE_CONNECTION=sync

#######################################
# MAIL - Locale
#######################################
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@solaryatravel.com"
MAIL_FROM_NAME="${APP_NAME}"

#######################################
# STRIPE - TEST MODE
#######################################
STRIPE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

#######################################
# PAYPAL - SANDBOX
#######################################
PAYPAL_MODE=sandbox
PAYPAL_SANDBOX_CLIENT_ID=
PAYPAL_SANDBOX_CLIENT_SECRET=
PAYPAL_LIVE_CLIENT_ID=
PAYPAL_LIVE_CLIENT_SECRET=

#######################################
# FILE STORAGE
#######################################
FILESYSTEM_DISK=public

#######################################
# LOGGING
#######################################
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

#######################################
# TELESCOPE (Dev only)
#######################################
TELESCOPE_ENABLED=true

#######################################
# BOOKING SETTINGS
#######################################
BOOKING_PENDING_EXPIRY_MINUTES=30
BOOKING_ADVANCE_HOURS=24
BOOKING_MAX_DAYS_AHEAD=180
BOOKING_TAX_RATE=0.22

#######################################
# QR CODE
#######################################
QR_CODE_SIZE=300
QR_CODE_STORAGE=public

#######################################
# VITE (Development)
#######################################
VITE_APP_NAME="${APP_NAME}"
